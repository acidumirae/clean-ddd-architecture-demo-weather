@model WeatherApp.Domain.Entities.WeatherForecast

@{
    ViewData["Title"] = "7-Day Forecast";
}

<div class="text-center mt-5">
    <h1 class="display-4">7-Day Weather Forecast</h1>

    <form method="get" class="mb-4" role="search" aria-label="Weather forecast search">
        <div class="input-group justify-content-center" style="max-width: 400px; margin: 0 auto;">
            <label for="location" class="visually-hidden">City name</label>
            <input type="text" id="location" name="location" class="form-control" placeholder="Enter city name..." value="@Context.Request.Query["location"]" />
            <button type="submit" class="btn btn-primary">Search</button>
        </div>
    </form>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger" role="alert">
            @ViewBag.Error
        </div>
    }
    else if (Model != null)
    {
        <h2 class="mb-3">@Model.Location</h2>

        <div style="max-width: 700px; margin: 0 auto;">
            <table class="table table-striped table-bordered" aria-label="7-day weather forecast for @Model.Location">
                <thead class="table-dark">
                    <tr>
                        <th scope="col">Date</th>
                        <th scope="col">Max Temp (°C)</th>
                        <th scope="col">Min Temp (°C)</th>
                        <th scope="col">Description</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var day in Model.Days)
                    {
                        <tr>
                            <td>@day.Date.ToString("ddd, dd MMM yyyy")</td>
                            <td>@day.MaxTempC °C</td>
                            <td>@day.MinTempC °C</td>
                            <td>@day.Description</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
