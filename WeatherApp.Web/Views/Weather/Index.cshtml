@model WeatherApp.Domain.Entities.Weather

@{
    ViewData["Title"] = "Weather";
}

<div class="text-center mt-5">
    <h1 class="display-4">Current Weather</h1>

    <form method="get" class="mb-4">
        <div class="input-group justify-content-center" style="max-width: 400px; margin: 0 auto;">
            <input type="text" name="location" class="form-control" placeholder="Enter city name..." value="@Context.Request.Query["location"]" />
            <button type="submit" class="btn btn-primary">Search</button>
        </div>
    </form>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger" role="alert">
            @ViewBag.Error
        </div>
    }
    else if (Model != null)
    {
        <div class="card shadow-sm" style="max-width: 400px; margin: 0 auto;">
            <div class="card-body">
                <h2 class="card-title">@Model.Location</h2>
                <h3 class="card-subtitle mb-2 text-muted">@Model.TemperatureC °C / @Model.TemperatureF °F</h3>
                <p class="card-text form-text">@Model.Description</p>
                <p class="text-muted small">Updated: @Model.LastUpdated.ToLocalTime()</p>
            </div>
        </div>
    }
</div>
